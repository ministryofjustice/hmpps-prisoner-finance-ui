{%- extends "govuk/template.njk" -%}

{%- from "govuk/components/back-link/macro.njk" import govukBackLink -%}

{%- set mainClasses = "govuk-body" -%}

{% block head %}
  <link href="{{ '/assets/css/index.css' | assetMap }}" rel="stylesheet"/>
  {% for css in feComponents.cssIncludes %}
    <link href="{{ css }}" nonce="{{ cspNonce }}" rel="stylesheet" />
  {% endfor %}
{% endblock %}

{% block pageTitle %}{% if pageTitle %}{{ pageTitle }} - {% endif %}{{ applicationName }}{% endblock %}

{% block header %}
  {{ feComponents.header  | safe }}
  {% include "../partials/phaseBanner.njk" %}
{% endblock %}

{% block containerStart %}
  {%- if backUrl -%}
    {{ govukBackLink({
      text: (backText if backText or "Back"),
      href: backUrl
    }) }}
  {%- endif -%}
  {% block beforeContent %}{% endblock %}
{%- endblock -%}

{% block footer %}
  {{ feComponents.footer | safe }}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ '/assets/js/index.js' | assetMap }}"></script>
  {% for js in feComponents.jsIncludes %}
    <script src="{{ js }}" nonce="{{ cspNonce }}"></script>
  {% endfor %}
{% endblock %}
