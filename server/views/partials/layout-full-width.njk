{%- extends "../partials/layout.njk" -%}

{%- set mainClasses = "govuk-body layout-full-width" -%}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {%- set classes = "" if backUrl else "govuk-!-static-margin-top-8" -%}
      <h1 class="govuk-heading-xl {{ classes }}">{{ pageTitle }}</h1>
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% block contentHeader %}{% endblock %}
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% block innerContent %}{% endblock %}
    </div>
  </div>
{% endblock %}
