{%- from "govuk/components/button/macro.njk" import govukButton -%}
{%- from "govuk/components/fieldset/macro.njk" import govukFieldset -%}
{%- from "govuk/components/input/macro.njk" import govukInput -%}

{% macro amountForm(params) %}
  <form method="POST" action="{{params.action}}" class="{{params.additionalClasses}}" data-testid='select-amount'>
    <input type="hidden" name="_csrf" value="{{ params.csrfToken }}">

    {% call govukFieldset({
      legend: {
        text: params.headingText,
        classes: "govuk-fieldset__legend--xl",
        isPageHeading: true
      }
    }) %}
      {{ govukInput({
        label: {
          text: "Amount"
        },
        id: "amount",
        name: "amount",
        prefix: {
          text: "£"
        },
        classes: "govuk-input--width-10",
        errorMessage: { text: params.errorMap.amount } if params.errorMap.amount else null,
        value: params.amountValue
      }) }}

      {{ govukInput({
        label: {
          text: "Description"
        },
        id: "description",
        name: "description",
        errorMessage: { text: params.errorMap.description } if params.errorMap.description else null,
        value: params.descriptionValue
      }) }}
    {% endcall %}

    {{ govukButton({
      text: "Done",
      type: "submit",
      preventDoubleClick: true
    }) }}
  </form>
  {% endmacro %}
