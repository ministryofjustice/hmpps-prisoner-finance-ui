{% macro summaryContainer(params, caller) %}
  <div class="hmpps-summary-container" data-testid="{{ params['data-testid'] }}">
    <div class="hmpps-summary-container__header">
      <h2 class="hmpps-summary-container__heading">{{ params.heading }}</h2>
    </div>
    {{ caller() }}
  </div>
{% endmacro %}
