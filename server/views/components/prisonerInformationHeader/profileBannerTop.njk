<div class="hmpps-profile-banner-top">
  <div class="hmpps-profile-banner-photo">
    <img class="hmpps-profile-photo" data-testid="prisonerProfileImage" src="/assets/images/prisoner-profile-image.png" alt="Photo of {{ params.prisoner.firstName }} {{ params.prisoner.lastName }} is not available" data-qa="prisoner-photo"/>
  </div>

  <h1 class="govuk-heading-xl hmpps-profile-prisoner-name" data-testid="prisonerName">
    {{ params.prisoner.lastName | capitalize }}, {{ params.prisoner.firstName | capitalize }}
  </h1>

  <div class="info">
    <p class="govuk-body hmpps-profile-prisoner-number" data-testid="prisonerNumber">
      {{ params.prisoner.prisonerNumber }}<span class="govuk-visually-hidden"> prison number</span>
    </p>

    <div class="info__links">
        <div>
          <h3>Location</h3>
          <a data-testid="cell-location" href="#">
            {{ params.prisoner.cellLocation }}<span class="govuk-visually-hidden"> location</span>
          </a>
        </div>
        <div>
          <h3>Category</h3>
          <a data-testid="category" href="#">
            {{ params.prisoner.category | default("Not entered") }}<span class="govuk-visually-hidden"> category</span>
          </a>
        </div>
        <div>
          <h3>CSRA</h3>
          <a data-testid="csra" href="#">
            {{ params.prisoner.csra | default("Not entered") }}<span class="govuk-visually-hidden"> CSRA</span>
          </a>
        </div>
        <div>
          <h3>Incentive level</h3>
          <a data-testid="incentive-level" href="#">
            {{ params.prisoner.currentIncentive.level.description }}<span class="govuk-visually-hidden"> incentive level</span>
          </a>
        </div>
    </div>
  </div>
</div>

<div class="hmpps-profile-banner-alerts">
  <ul class="alerts-list" data-qa="alert-flags">
  </ul>
</div>
