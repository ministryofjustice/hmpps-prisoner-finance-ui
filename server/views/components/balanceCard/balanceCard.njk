{%- macro balanceCard(params) -%}
  <div class="card card--clickable hmpps-balance-card">
    <h2 class="govuk-heading-m card__heading hmpps-balance-card__header">{{ params.heading }}</h2>

    <div class="hmpps-balance-card__body">
      <p class="govuk-body card__description hmpps-balance-card__description">Total</p>
      <p class="govuk-body hmpps-balance-card__total">&pound;{{ params.amount | penceToPound }}</p>

    {% if params.link %}
      <p class="govuk-body hmpps-balance-card__action">
        <a class="govuk-link card__link govuk-link--no-visited-state" href="{{params.link.href}}">{{params.link.text}}</a>
      </p>
    {% endif %}
    </div>
  </div>
{%- endmacro -%}
