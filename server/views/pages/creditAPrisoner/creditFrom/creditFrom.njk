{%- extends "partials/layout-wizard-step.njk" -%}

{%- from "components/forms/radiosSelectionForm.njk" import radiosSelectionForm -%}

{%- set pageTitle = "Credit a prisoner from" -%}
{%- set backUrl = "./credit-to" -%}
{%- set showPrisonerInformation = true -%}

{% block innerContent %}
  {{ radiosSelectionForm({
    additionalClasses: "hmpps-subaccount-select",
    action: "./credit-from",
    csrfToken: csrfToken,
    headingText: "Credit from",
    subHeading: null,
    radiosId: "creditFrom",
    radiosValue: debitSubAccountId,
    radiosItems: items,
    errorMap: errorMap
  }) }}
{% endblock %}
