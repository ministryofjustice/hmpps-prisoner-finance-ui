{% extends "partials/layout.njk" %}

{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/fieldset/macro.njk" import govukFieldset %}

{% from "components/prisonerInformationHeader/prisonerInformationHeader.njk" import prisonerInformationHeader %}

{% set pageTitle = applicationName + " - Profile" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}

  <a href="/" id="backLink" class="govuk-back-link" data-testid="backLink">Back</a>

  {{ prisonerInformationHeader({
      prisoner:prisoner
  }) }}


{% endblock %}

{% block content %}

<div class="credit-from-page govuk-grid-row">

  <form method="POST" action="./credit-from" data-testid='select-credit-from-account'>

  <input type="hidden" name="_csrf" value="{{ csrfToken }}">


{% call govukFieldset({
  legend: {
    text: "Credit from",
    classes: "govuk-fieldset__legend--l",
    isPageHeading: true
  }
}) %}

    {{ govukRadios({
      name: "creditFrom",
      fieldset: {
      },
      value: debitSubAccountId,
      items: items ,
      errorMessage: { text: errorMap.errorText } if errorMap.errorText else null
    }) }}



    {% endcall %}

    {{ govukButton({
      text: "Continue",
      type: "submit",
       attributes:{
            "data-testid" : "continue-button"
            }
    }) }}

  </form>
</div>

{% endblock %}
