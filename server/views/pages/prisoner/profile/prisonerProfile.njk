{%- extends "partials/layout-three-quarters.njk" -%}

{%- from "govuk/components/table/macro.njk" import govukTable -%}
{%- from "components/summaryContainer/summaryContainer.njk" import summaryContainer -%}
{%- from "components/balanceCard/balanceCard.njk" import balanceCard -%}
{%- from "components/actionBlock/actionBlock.njk" import actionBlock -%}
{%- from "partials/data-warning-banner/macro.njk" import dataWarningBanner -%}

{%- set pageTitle = "Finances" -%}
{%- set backUrl = "/prisoner" -%}

{% block contentHeader %}
  {{ dataWarningBanner(dataWarningBannerEnabled) }}
{% endblock %}

{% block innerContent %}
  <div class="hmpps-balance-card-group">
    <ul class="govuk-grid-row card-group">
      <li class="govuk-grid-column-one-third card-group__item">
        {{ balanceCard({
          heading: "Spends",
          amount: subAccountBalances.spends.amount,
          link: {
            href: "/prisoner/"+prisonNumber+"/money/spends",
            text: "Spends transactions"
          }
        }) }}
      </li>
      <li class="govuk-grid-column-one-third card-group__item">
        {{ balanceCard({
          heading: "Private cash",
          amount: subAccountBalances.privateCash.amount,
          link: {
            href: "/prisoner/"+prisonNumber+"/money/private-cash",
            text: "Private cash transactions"
          }
        }) }}
      </li>
      <li class="govuk-grid-column-one-third card-group__item">
        {{ balanceCard({
          heading: "Savings",
          amount: subAccountBalances.savings.amount,
          link: {
            href: "/prisoner/"+prisonNumber+"/money/savings",
            text: "Savings transactions"
          }
        }) }}
    </ul>
  </div>

  {% set tableRows = [] %}
  {% for row in transactions %}
    {%- set balance = row.accountBalance if row.accountBalance is defined else null -%}
    {%- set amount = row.credit if row.credit > 0 else -1 * row.debit -%}
    {%- set amountClass = "amount-credit" if row.credit > 0 else "amount-debit" -%}
    {%- set rowData = [
      { text: row.date | formatDateForView },
      { text: row.description },
      { text: amount | penceToPound, format: "numeric", classes: amountClass },
      { text: (balance | penceToPound) if balance !== null else '-', format: "numeric" },
      { text: row.accountType | formatPrisonerAccountType }
    ] -%}
    {% set tableRows = (tableRows.push(rowData), tableRows) %}
  {% endfor %}

  {% call summaryContainer({
    heading : "All account transactions",
    "testId" : "prisoner-transactions-table-container"
  }) %}
    <div class="hmpps-summary-container__table_container">
      {% if transactions | length > 0 %}
        {{ govukTable({
            attributes: {
              "data-testid": "prisoner-transactions-table"
            },
            classes: "transaction-table",
            head: [
              { text: "Date" },
              { text: "Transaction description" },
              { text: "Amount", format: "numeric" },
              { text: "Balance", format: "numeric" },
              { text: "Account" }
            ],
            rows: tableRows
          }) }}
      {% else %}
        <p data-testid="no-transactions-message"> No transactions to show </p>
      {% endif %}
    </div>

    <p class="govuk-body">
      <a href="/prisoner/{{prisonNumber}}/money" data-testid="transactions-page-link" >View all transactions</a>
    </p>
  {% endcall %}
{% endblock %}

{% block secondaryContent %}
  {{ actionBlock({
    actions: [
      {text: "Credit account", 'dataTestId': 'credit-menu', url:"/prisoner/"+prisonNumber+"/money/credit-a-prisoner/credit-to"},
      {text: "Debit account", 'dataTestId': 'debit-menu'},
      {text: "Sub account transfer", 'dataTestId': 'subaccount-menu'},
      {text: "Adjudications", 'dataTestId': 'adjudications-menu'},
      {text: "Export statement", 'dataTestId': 'export-menu'},
      {text: "Close account", 'dataTestId': 'close-menu'}
    ]
  }) }}
{% endblock %}
