{% from "components/summaryContainer/summaryContainer.njk" import summaryContainer %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% extends "../../../partials/layout.njk" %}

{% set pageTitle = applicationName + " - Profile" %}
{% set mainClasses = "govuk-body" %}

{% block content %}

{% set tableRows = [] %}


{% for i in range(5) %}
  {% if i < transactions | length %}
    {% set row = transactions[i] %}
    {% set rowData = [
      { text: row.date | formatDateForView },
      { text: row.description },
      { text: row.accountType },
      { text: (row.credit | penceToPound)},
      { text: (row.debit | penceToPound)}
    ] %}
    {% set tableRows = (tableRows.push(rowData), tableRows) %}
  {% endif %}
{% endfor %}
<div class="govuk-grid-column-two-thirds">
{% call summaryContainer({ heading : "Prisoner's transactions"}) %}
      {{ govukTable({
    attributes: {
      "data-testid": "prisoner-transactions-table"
    },
    head: [
      { text: "Date" },
      { text: "Transaction description" },
      { text: "Account Type" },
      { text: "Credit" },
      { text: "Debit" }
    ],
    rows: tableRows
  }) }}
</div>
{% endcall %}
{% endblock %}
