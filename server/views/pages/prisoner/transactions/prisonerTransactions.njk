{% extends "partials/layout.njk" %}

{% from "components/balanceCard/balanceCard.njk" import balanceCard %}
{% from "components/prisonerInformationHeader/prisonerInformationHeader.njk" import prisonerInformationHeader %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "moj/components/filter/macro.njk" import mojFilter %}
{% from "moj/components/date-picker/macro.njk" import mojDatePicker %}
{% from "moj/components/pagination/macro.njk" import mojPagination %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}

{% set pageTitle = applicationName + " - Finance" %}
{% set mainClasses = "govuk-body" %}

{% block beforeContent %}

<a href="/prisoner/{{prisonNumber}}" id="backLink" class="govuk-back-link" data-testid="backLink">Back</a>

  {{ prisonerInformationHeader({
      prisoner:prisoner
  }) }}


{% endblock %}

{% block content %}
<div class="prisoner-transactions-page">

  <h1 id="prisonerTransactionsHeading">{{headerTitle}}</h1>

  <div class="govuk-grid-row">
    <div class="card-group govuk-grid-column-two-thirds" id="prisonerFinanceCard">
      <div class="govuk-grid-column-one-third  card-group__item">
        {{ balanceCard({
          "heading": "Current balance",
          "amount": currentBalance,
          "testId": "view-prisoner-current-balance-card",
          "showSubHeading": false
        }) }}
      </div>
      <div class="govuk-grid-column-one-third  card-group__item">
        {{ balanceCard({
          "heading": "Hold balance",
          "amount": holdBalance,
          "testId": "view-prisoner-hold-balance-card",
          "showSubHeading": false
        }) }}
      </div>
      <div class="govuk-grid-column-one-third  card-group__item">
        {{ balanceCard({
          "heading": "Total balance",
          "amount": currentBalance + holdBalance,
          "testId": "view-prisoner-total-balance-card",
          "showSubHeading": false
        }) }}
      </div>
    </div>
  </div>

  <div class="moj-filter-layout">
    <div class="moj-filter-layout__filter moj-filter-layout__filter--small"
        data-module="list-filter"
        data-filter-start-shown="true"
      >
      <div class="moj-filter">
        <form method="get" action="#filterForm" id="filterForm">
          {%- set filterOptionsHtml %}

            <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Date range</legend>

            {{ mojDatePicker({
              id: 'startDate',
              name: 'startDate',
              leadingZeros: 'true',
              label: { text: "From", classes: "govuk-label--s"},
              value: filters.startDate,
              hint: {
                text: "For example, 17/05/2024."
              },
              errorMessage: { text: errorMap.startDate } if errorMap.startDate else null
            }) }}

            {{ mojDatePicker({
              id: 'endDate',
              name: 'endDate',
              leadingZeros: 'true',
              label: { text: "To", classes: "govuk-label--s" },
              value: filters.endDate,
              hint: {
                text: "For example, 18/05/2024."
              },
              errorMessage: { text: errorMap.endDate } if errorMap.endDate else null
            }) }}

            {{ govukCheckboxes({
              name: "creditDebit",
              fieldset: {
                legend: {
                  text: "Credit or debit",
                  classes: "govuk-fieldset__legend--s"
                }
              },
              items: [
                {
                  name: "credit",
                  checked: filters.credit === 'true',
                  value: "true",
                  text: "Credit",
                  id: "creditFilter"
                },
                {
                  name: "debit",
                  checked: filters.debit === 'true',
                  value: "true",
                  text: "Debit",
                  id: "debitFilter"
                }
              ],
              errorMessage: {
                text: errorMap.credit | default("") + errorMap.debit | default("")
              } if errorMap.credit or errorMap.debit else null
            }) }}

          {% endset -%}

          {{ mojFilter({
              heading: {
                text: "Filter"
              },

              submit: {
                attributes: {
                    "data-test-id": "submit-button"
                }
              },

              selectedFilters: {
                heading: {
                  text: "Selected filters",
                  href: "?"
                },

                clearLink: {
                  text: "Clear filters",
                  href: '?#filterForm'
                },

                categories: filters.selectedFilters
                },
                optionsHtml: filterOptionsHtml
            })
          }}
        </form>
      </div>
    </div>

    <div class="moj-filter-layout__content">
      <div class="moj-action-bar">
        <div class="moj-action-bar__filter moj-action-bar__filter--no-actions"></div>
      </div>

      {% set tableRows = [] %}

      {% for row in transactions %}
        {% set rowData = [
          { text: row.date | formatDateForView },
          { text: row.description },
          { text: row.credit | penceToPound},
          { text: row.debit | penceToPound},
          { text: row.location | convertPrisonIdToName(prisonNames)},
          { text: row.accountType | formatPrisonerAccountType }
        ] %}
        {% set tableRows = (tableRows.push(rowData), tableRows) %}
      {% endfor %}

      {% if transactions | length > 0 %}

      <div id="top-pagination">
        {{ mojPagination(paginationItems) }}
      </div>

        {{ govukTable({
          attributes: {
            "data-testid": "prisoner-transactions-table"
          },
          caption: "",
          captionClasses: "govuk-table__caption--m",
          head: [
            { text: "Date of transaction" },
            { text: "Transaction description" },
            { text: "Credit" },
            { text: "Debit" },
            { text: "Location" },
            { text: "Account Type" }
          ],
          rows: tableRows
        }) }}

      <div id="bottom-pagination">
        {{ mojPagination(paginationItems) }}
      </div>

      {% else %}
        <p data-testid="no-transactions-message">
          {% if hasValidationErrors %}
            Please fix the filter's errors to view transactions
          {% else %}
            No transactions to show
          {% endif %}
        </p>
      {% endif %}
      </div>
  </div>
</div>


{% endblock %}
