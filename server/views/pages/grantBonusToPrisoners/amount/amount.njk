{%- extends "partials/layout-wizard-step.njk" -%}

{%- from "components/forms/amountForm.njk" import amountForm -%}

{%- set pageTitle = "Grant bonus to prisoners" -%}
{%- set backUrl = "/" -%}

{% block innerContent %}
  <div class="grant-bonus-to-prisoners-amount-page">
    {{ amountForm({
      action: "./amount",
      csrfToken: csrfToken,
      headingText: "Grant bonus to prisoners",
      errorMap: errorMap,
      amountValue : amount,
      descriptionValue : description
    }) }}
  </div>
{% endblock %}
