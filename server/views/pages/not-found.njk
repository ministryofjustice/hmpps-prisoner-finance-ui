{%- extends "partials/layout-two-thirds.njk" -%}

{%- from "govuk/components/button/macro.njk" import govukButton -%}

{%- set pageTitle = "Page not found" -%}
{%- set backUrl = "/" -%}

{% block innerContent %}
  <p class="govuk-body">If you typed the web address, check it is correct.</p>

  <p class="govuk-body">If you pasted the web address, check you copied it correctly.</p>

  <p class="govuk-body">If the web address is correct, or you selected a link or button you need to contact your local system administrator.</p>

  {{ govukButton({ text: "Continue", href: "/", attributes: { "data-testid": "continue-button" } }) }}
{% endblock %}
